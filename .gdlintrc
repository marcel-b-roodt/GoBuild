# gdlint configuration for GoBuild — YAML format
# https://github.com/Scony/godot-gdscript-toolkit

max-line-length: 100

# SelectionManager exposes ~20 small public methods (select/deselect/toggle 3
# element types + mode + bulk helpers).  Raise the cap rather than forcing
# artificial restructuring of a cohesive API.
# GdUnit4 test suites also accumulate many public test_ methods by design;
# 60 is generous enough for any test class while still catching bloated
# production classes.
max-public-methods: 60

# GoBuildGizmoPlugin grows legitimately: it owns all gizmo materials, cached
# meshes, drag-math methods (translate, rotate, plane, scale, viewport-plane),
# and mesh-builder statics.  1400 lines is a generous ceiling while still
# catching runaway growth.
max-file-lines: 1400

